# ===========================================================================
# WebReaper — Environment Variables
# ===========================================================================
# Copy this to .env and fill in your values.
# Docker Compose reads .env automatically.
# For local dev, source it: set -a && source .env && set +a
# ===========================================================================

# --- App ---
APP_ENV=production                  # "production" or "development"

# --- Database ---
# SQLite (local dev):
# DATABASE_URL=sqlite+aiosqlite:///~/.webreaper/webreaper.db
# PostgreSQL (production / Docker):
DATABASE_URL=postgresql+asyncpg://webreaper:CHANGE_ME@localhost:5432/webreaper
POSTGRES_PASSWORD=CHANGE_ME

# --- CORS ---
# Comma-separated list of allowed origins. Required in production.
CORS_ORIGINS=https://your-domain.com

# --- Auth (Supabase) — required for user authentication ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Billing (Stripe) — required for subscriptions ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...

# --- AI Digest (Claude) — optional, enables AI-powered crawl summaries ---
ANTHROPIC_API_KEY=sk-ant-...

# --- License (desktop/CLI mode) ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WEBREAPER_LICENSE_SECRET=

# --- Logging ---
WEBREAPER_LOG_LEVEL=INFO
